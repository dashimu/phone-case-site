    "@types/react-dom": "19.2.3",
    "@types/react-gravatar": "^2.6.14",
    "concurrently": "^10.0.3",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwind-bootstrap-grid": "^7.0.0",
