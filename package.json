    "@astrojs/sitemap": "^3.7.3",
    "@justinribeiro/lite-youtube": "^1.9.0",
    "@nanostores/react": "^1.1.0",
    "astro": "^7.0.0",
    "astro-auto-import": "^0.5.1",
    "astro-font": "^1.1.0",
    "astro-gtm-lite": "^1.0.1",
    "date-fns": "^4.4.0",
    "github-slugger": "^2.0.0",
    "js-cookie": "^3.0.8",
    "marked": "^18.0.5",
    "nanostores": "^1.3.0",
    "prop-types": "^15.8.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
