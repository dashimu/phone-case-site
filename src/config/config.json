{
  "site": {
    "title": "Phone Case Store",
    "base_url": "https://phone-case-site.pages.dev/",
    "base_path": "/",
    "trailing_slash": false,
    "favicon": "/images/favicon.png",
    "logo": "/images/logo.png",
    "logo_darkmode": "/images/logo-darkmode.png",
    "logo_width": "150",
    "logo_height": "33",
    "logo_text": "Phone Case Store"
  },

  "announcement": {
    "enable": true,
