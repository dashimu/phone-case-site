  },

  "google_tag_manager": {
    "enable": false,
    "gtm_id": "GTM-XXXXXX"
  },

  "metadata": {
    "meta_author": "Phone Case Store",
    "meta_image": "/images/og-image.png",
    "meta_description": "Stylish and protective phone cases for daily use."
  },

  "shopify": {
    "currencySymbol": "$",
